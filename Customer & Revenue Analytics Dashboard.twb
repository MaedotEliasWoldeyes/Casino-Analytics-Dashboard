              <calculation class='tableau' formula='IF { FIXED [player_id] : SUM([total_wager]) } &gt;=1500 THEN &quot;VIP&quot;&#13;&#10;ELSEIF { FIXED [player_id] : SUM([total_wager]) } &gt;= 300 THEN &quot;Regular&quot;&#13;&#10;ELSE &quot;Casual&quot;&#13;&#10;END' />
